# Copy this file to .env and fill in the values.
# .env is never committed (it is in .gitignore).

# ── Role of this node ─────────────────────────────────────────────────────────
# primary   → runs MongoDB + Neo4j locally + crawler
# secondary → crawler only; the database lives on the primary node
ROLE=primary

# ── Address of the primary node (required only if ROLE=secondary) ─────────────
DB_HOST=

# ── Crawler ───────────────────────────────────────────────────────────────────
WORKERS=3
SHARD=0
SHARDS=1
ACCOUNTS=accounts.json
